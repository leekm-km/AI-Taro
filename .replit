modules = ["python-3.12"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["flutter", "dart"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 45103
externalPort = 3000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Tarot App Server"

[[workflows.workflow]]
name = "Tarot App Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd ai_taro_oppa/backend && uvicorn main:app --host 0.0.0.0 --port 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[deployment]
deploymentTarget = "autoscale"
run = ["uvicorn", "ai_taro_oppa.backend.main:app", "--host", "0.0.0.0", "--port", "5000"]
build = ["sh", "-c", "cd ai_taro_oppa && flutter pub get && flutter build web --release"]
